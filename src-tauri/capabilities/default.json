{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "opener:default",
        "dialog:allow-save",
        "dialog:allow-open",
        "dialog:allow-message",
        "dialog:allow-ask",
        "shell:allow-execute",
        "shell:allow-stdin-write",
        "shell:allow-open"
    ]
}