{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Android SDCard File Manager",
    "version": "0.1.2",
    "identifier": "com.liaochenliang.sdcard-file-manager",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [{
            "title": "ADB SDCard 文件管理器",
            "width": 1100,
            "height": 700
        }],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": [
            "binaries/adb"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}